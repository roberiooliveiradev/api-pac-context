# =============================================================================
# API PAC Context — srv-api (produção)
# =============================================================================
# Uso no servidor:
#   cd ~/projetos/api-pac-context
#   cp .env.srv-api.example .env
#   grep API_DELPI_INTERNAL_SERVICE_TOKEN ~/projetos/delpi-central/infra/.env
#   nano .env
#   cp docker-compose.override.srv-api.example.yml docker-compose.override.yml
#   docker compose up -d --build
#
# Subdomínio Cloudflare: docs/cloudflare-subdominio-pac-context-api.md
#   https://pac-context-api.minhadelpi.com.br
# =============================================================================

# --- Servidor API (porta só interna ao Docker) ---
API_PAC_CONTEXT_PORT=8011
API_PAC_CONTEXT_ENV=production
LOG_LEVEL=INFO
TZ=America/Sao_Paulo

API_PAC_ROOT_PATH=

PUBLIC_BASE_URL=https://pac-context-api.minhadelpi.com.br

# --- Nginx (porta no HOST) ---
# srv-api: 80 = delpi-gateway, 8082 = api-pac-quality — use 8083 para context.
# Verifique: ss -tlnp | grep -E ':8082 |:8083 '
NGINX_HTTP_PORT=8083

# Chave API para Custom GPT (Actions — Bearer ou X-Api-Key)
# Gerar: openssl rand -hex 32
PAC_CONTEXT_API_KEY=

# --- api-delpi (obrigatório — delegação S2S) ---
API_DELPI_BASE_URL=http://delpi-api-delpi:8000
API_DELPI_INTERNAL_SERVICE_TOKEN=COLE_DO_delpi-central_infra_.env
API_DELPI_TIMEOUT_SECONDS=60
