# API PAC Context — leitura investigativa para GPT (delegação api-delpi)
API_PAC_CONTEXT_PORT=8011
API_PAC_CONTEXT_ENV=development
LOG_LEVEL=INFO
# Diretório (no host) dos logs persistentes de request — volume :/app/logs
# Default: ./logs ao lado do docker-compose.yml
PAC_CONTEXT_LOG_DIR=./logs
PUBLIC_BASE_URL=http://localhost:8011

# Autenticação entrada (Custom GPT)
PAC_CONTEXT_API_KEY=

# Delegação S2S api-delpi (obrigatório)
API_DELPI_BASE_URL=http://delpi-api-delpi:8000
API_DELPI_INTERNAL_SERVICE_TOKEN=
API_DELPI_TIMEOUT_SECONDS=60
